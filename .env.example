MONGO_URI=mongodb://usuario:senha@host:27017/evoluta-hub?authSource=admin
JWT_SECRET=gere_com_openssl_rand_base64_32
ADMIN_PASSWORD=senha_forte_aqui

# Cloudflare Tunnel — obtenha em zero.cloudflare.com > Networks > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiXXXXXXXX...

# CORS — domínio público do hub (ex: https://hub.manoelvolis.online)
ALLOWED_ORIGIN=https://seu-dominio.com

# n8n — Webhooks de integração com os motores
# Em produção Docker: use a URL interna do container (ex: http://n8n:5678/webhook/...)
# para evitar loopback via Cloudflare Tunnel.
# Em dev local: use a URL pública normalmente.
N8N_WEBHOOK_EXTRAIR=http://n8n:5678/webhook/uuid-do-extrair
N8N_WEBHOOK_RELATORIO=http://n8n:5678/webhook/uuid-do-relatorio
N8N_WEBHOOK_BENCHMARK=http://n8n:5678/webhook/benchmark/gerar
